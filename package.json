{
  "name": "ramblemaxxer",
  "version": "0.1.0",
  "private": true,
  "description": "Schedule optimization for Loyola University Chicago students",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "cd server && npm start",
    "db:init": "cd server && node db/init.js",
    "db:seed": "cd server && node db/seed.js",
    "db:scrape": "cd server && node scripts/scrape-catalog.js",
    "db:seed-courses": "cd server && node scripts/seed-courses.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
